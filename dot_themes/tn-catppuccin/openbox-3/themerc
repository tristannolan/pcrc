# Menu
menu.border.color: #d3dae3

menu.title.bg: Solid Flat
menu.title.bg.color: #181825
menu.title.bg.shadow: 0
menu.title.text.color: #d3dae3
menu.title.text.justify: Center

menu.items.bg: Solid Flat
menu.items.bg.color: #181825
menu.items.text.color: #d3dae3
menu.items.disabled.text.color: #a4a9b3

menu.items.active.bg: Solid Flat
menu.items.active.bg.color: #cba6f7
menu.items.active.text.color: #d3dae3

menu.separator.color: #a4a9b3
menu.separator.width: 1
menu.separator.padding.width: 2
menu.separator.padding.height: 4

# Window focused
window.active.title.separator.color: #181825

# Active window
window.active.border.color: #303641


window.active.title.bg: flat solid
window.active.title.bg.color: #181825
window.active.title.separator.color: #181825
window.active.text.justify: center

window.active.label.bg: parentrelative
window.active.label.text.color: #d3dae3

window.active.handle.bg: flat solid
window.active.handle.bg.color: #181825

window.active.grip.bg: flat solid
window.active.grip.bg.color: #181825

window.active.button.unpressed.bg: flat solid
window.active.button.unpressed.bg.color: #181825
window.active.button.unpressed.image.color: #d3dae3

window.active.button.pressed.bg: flat solid
window.active.button.pressed.bg.color: #cba6f7
window.active.button.pressed.image.color: #1e1e2e

window.active.button.disabled.bg: flat solid
window.active.button.disabled.bg.color: #181825
window.active.button.disabled.image.color: #a4a9b3

window.active.button.hover.bg: flat solid
window.active.button.hover.bg.color: #181825
window.active.button.hover.image.color: #cba6f7

#window.active.button.toggled.bg: #cba6f7
#window.active.button.toggled.image.color: #1e1e2e

# Inactive window
window.inactive.border.color: #303641

window.inactive.title.bg: flat solid
window.inactive.title.bg.color: #181825
window.inactive.title.separator.color: #181825
window.inactive.text.justify: center

window.inactive.label.bg: parentrelative
window.inactive.label.text.color: #a4a9b3

window.inactive.handle.bg: flat solid
window.inactive.handle.bg.color: #181825

window.inactive.grip.bg: flat solid
window.inactive.grip.bg.color: #181825

window.inactive.button.unpressed.bg: flat solid
window.inactive.button.unpressed.bg.color: #181825
window.inactive.button.unpressed.image.color: #a4a9b3

window.inactive.button.pressed.bg: flat solid
window.inactive.button.pressed.bg.color: #cba6f7
window.inactive.button.pressed.image.color: #1e1e2e

window.inactive.button.disabled.bg: flat solid
window.inactive.button.disabled.bg.color: #a4a9b3
window.inactive.button.disabled.image.color: #181825

window.inactive.button.hover.bg: flat solid
window.inactive.button.hover.bg.color: #181825
window.inactive.button.hover.image.color: #cba6f7


# OSD
osd.border.width: 1
osd.border.color: #cba6f7

osd.bg: flat solid
osd.bg.color: #181825
osd.label.bg: flat solid
osd.label.bg.color: #181825
osd.label.text.color: #d3dae3

# OSD
osd.bg: Solid Flat
osd.bg.color: #181825
osd.bg.shadow: 0

osd.border.width: 2
osd.hilight.bg: Solid Flat
osd.hilight.bg.color: #cba6f7
osd.unhilight.bg: flat solid
osd.unhilight.bg.color: #1e1e2e

osd.button.unpressed.bg: flat border
osd.button.unpressed.bg.color: #45475a
#osd.button.unpressed.*.border.color: #d3dae3

osd.button.pressed.bg: flat border
osd.button.pressed.bg.color: #cba6f7
#osd.button.pressed.*.border.color: #1e1e2e

osd.button.focused.bg: flat solid border
osd.button.focused.bg.color: #d3dae3
#osd.button.focused.*.border.color: #1e1e2e

osd.button.focused.box.color: #cba6f7


# Fonts
window.active.label.text.font:shadow=n
window.inactive.label.text.font:shadow=n
menu.items.font:shadow=n
menu.title.text.font:shadow=n


# Everything else
border.width: 2
padding.width: 8
padding.height: 2
window.handle.width: 0
window.client.padding.width: 0
window.label.text.justify: center
#menu.overlap: 0
